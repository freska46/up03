  "components": {
    "schemas": {
      "Game": {
        "required": [
          "genre",
          "pricePerHour",
          "title"
        ],
        "type": "object",
        "properties": {
          "gameId": {
            "type": "integer",
            "format": "int32"
          },
          "title": {
            "maxLength": 100,
            "minLength": 1,
            "type": "string"
          },
          "genre": {
            "maxLength": 50,
            "minLength": 1,
            "type": "string"
          },
          "pricePerHour": {
            "type": "number",
            "format": "double"
          },
          "available": {
            "type": "boolean"
          },
          "sessions": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Session"
            },
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "Session": {
        "required": [
          "gameId",
          "startTime",
          "userId"
        ],
        "type": "object",
        "properties": {
          "sessionId": {
            "type": "integer",
            "format": "int32"
          },
          "userId": {
            "type": "integer",
