<Window x:Class="PakDzal_Games_WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Игровой клуб (PakDzal Games)"
        Height="750" Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundDarkBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource PrimaryPurpleDarkBrush}" Padding="20">
            <Grid>
                <TextBlock Text="ИГРОВОЙ КЛУБ (PakDzal Games)"
                           FontSize="28"
                           FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           HorizontalAlignment="Center"/>
            </Grid>
        </Border>

        <TabControl Grid.Row="1" Background="Transparent" Margin="10">
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="Background" Value="{StaticResource CardBackgroundBrush}"/>
                    <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                    <Setter Property="Padding" Value="20,10"/>
                    <Setter Property="FontSize" Value="16"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TabItem">
                                <Border x:Name="Border"
                                        Background="{TemplateBinding Background}"
                                        BorderThickness="0,0,0,3"
                                        BorderBrush="Transparent"
                                        Padding="{TemplateBinding Padding}"
                                        Margin="2">
                                    <ContentPresenter ContentSource="Header"
                                                    HorizontalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource LightPurpleBrush}"/>
                                        <Setter TargetName="Border" Property="Background" Value="{StaticResource PrimaryPurpleBrush}"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Border" Property="Background" Value="{StaticResource PrimaryPurpleBrush}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </TabControl.Resources>

            <TabItem Header="Пользователи">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="Поиск:" Foreground="{StaticResource TextPrimaryBrush}" Margin="5,0,0,5"/>
                            <TextBox x:Name="txtUserSearch" Width="250" Style="{StaticResource ModernTextBoxStyle}"/>
                        </StackPanel>
                        <StackPanel Margin="10,0">
                            <TextBlock Text="Город:" Foreground="{StaticResource TextPrimaryBrush}" Margin="5,0,0,5"/>
                            <TextBox x:Name="txtUserCity" Width="130" Style="{StaticResource ModernTextBoxStyle}"/>
                        </StackPanel>
                        <Button Content="Поиск" Style="{StaticResource MainButtonStyle}" VerticalAlignment="Bottom"
                                Click="btnUserSearch_Click"/>
                        <Button Content="Сброс" Style="{StaticResource SecondaryButtonStyle}" VerticalAlignment="Bottom"
                                Click="btnUserReset_Click"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
                        <Button Content="Добавить" Style="{StaticResource MainButtonStyle}"
                                Click="btnAddUser_Click"/>
                        <Button Content="Изменить" Style="{StaticResource SecondaryButtonStyle}"
                                Click="btnEditUser_Click"/>
                        <Button Content="Удалить" Style="{StaticResource DangerButtonStyle}"
                                Click="btnDeleteUser_Click"/>
                        <Button Content="Отчет" Style="{StaticResource MainButtonStyle}"
                                Click="btnUserReport_Click"/>
                    </StackPanel>

                    <DataGrid Grid.Row="2" x:Name="dgUsers"
                              Style="{StaticResource ModernDataGridStyle}"
                              CellStyle="{StaticResource DataGridCellStyle}"
                              ColumnHeaderStyle="{StaticResource DataGridColumnHeaderStyle}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding UserId}" Width="50"/>
                            <DataGridTextColumn Header="Имя" Binding="{Binding Name}" Width="150"/>
                            <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="180"/>
                            <DataGridTextColumn Header="Телефон" Binding="{Binding Phone}" Width="180"/>
                            <DataGridTextColumn Header="Город" Binding="{Binding City}" Width="100"/>
                            <DataGridTextColumn Header="Дата регистрации" Binding="{Binding RegistrationDate, StringFormat=dd.MM.yyyy}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <TabItem Header="Игры">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="Поиск:" Foreground="{StaticResource TextPrimaryBrush}" Margin="5,0,0,5"/>
                            <TextBox x:Name="txtGameSearch" Width="200" Style="{StaticResource ModernTextBoxStyle}"/>
                        </StackPanel>
                        <StackPanel Margin="10,0,0,0">
                            <TextBlock Text="Жанр:" Foreground="{StaticResource TextPrimaryBrush}" Margin="5,0,0,5"/>
                            <ComboBox x:Name="cmbGameGenre" Width="130" Style="{StaticResource ModernComboBoxStyle}"/>
                        </StackPanel>
                        <StackPanel Margin="10,0,0,0">
                            <TextBlock Text="Только доступные:" Foreground="{StaticResource TextPrimaryBrush}" Margin="5,0,0,5"/>
                            <CheckBox x:Name="chkGameAvailable" Content=""
                                      VerticalAlignment="Center"/>
                        </StackPanel>
                        <Button Content="Поиск" Style="{StaticResource MainButtonStyle}" VerticalAlignment="Bottom"
                                Click="btnGameSearch_Click"/>
                        <Button Content="Сброс" Style="{StaticResource SecondaryButtonStyle}" VerticalAlignment="Bottom"
                                Click="btnGameReset_Click"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
                        <Button Content="Добавить" Style="{StaticResource MainButtonStyle}"
                                Click="btnAddGame_Click"/>
                        <Button Content="Изменить" Style="{StaticResource SecondaryButtonStyle}"
                                Click="btnEditGame_Click"/>
                        <Button Content="Удалить" Style="{StaticResource DangerButtonStyle}"
                                Click="btnDeleteGame_Click"/>
                        <Button Content="Отчет" Style="{StaticResource MainButtonStyle}"
                                Click="btnGameReport_Click"/>
                    </StackPanel>

                    <DataGrid Grid.Row="2" x:Name="dgGames"
                              Style="{StaticResource ModernDataGridStyle}"
                              CellStyle="{StaticResource DataGridCellStyle}"
                              ColumnHeaderStyle="{StaticResource DataGridColumnHeaderStyle}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding GameId}" Width="50"/>
                            <DataGridTextColumn Header="Название" Binding="{Binding Title}" Width="200"/>
                            <DataGridTextColumn Header="Жанр" Binding="{Binding Genre}" Width="150"/>
                            <DataGridTextColumn Header="Цена/час" Binding="{Binding PricePerHour, StringFormat=N2}" Width="100"/>
                            <DataGridCheckBoxColumn Header="Доступна" Binding="{Binding Available}" Width="90"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <TabItem Header="Сессии">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="Пользователь:" Foreground="{StaticResource TextPrimaryBrush}" Margin="5,0,0,5"/>
                            <ComboBox x:Name="cmbSessionUser" Width="180" Style="{StaticResource ModernComboBoxStyle}"/>
                        </StackPanel>
                        <StackPanel Margin="10,0">
                            <TextBlock Text="Игра:" Foreground="{StaticResource TextPrimaryBrush}" Margin="5,0,0,5"/>
                            <ComboBox x:Name="cmbSessionGame" Width="180" Style="{StaticResource ModernComboBoxStyle}"/>
                        </StackPanel>
                        <Button Content="Фильтр" Style="{StaticResource MainButtonStyle}" VerticalAlignment="Bottom"
                                Click="btnSessionFilter_Click"/>
                        <Button Content="Сброс" Style="{StaticResource SecondaryButtonStyle}" VerticalAlignment="Bottom"
                                Click="btnSessionReset_Click"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
                        <Button Content="Добавить" Style="{StaticResource MainButtonStyle}"
                                Click="btnAddSession_Click"/>
                        <Button Content="Изменить" Style="{StaticResource SecondaryButtonStyle}"
                                Click="btnEditSession_Click"/>
                        <Button Content="Удалить" Style="{StaticResource DangerButtonStyle}"
                                Click="btnDeleteSession_Click"/>
                        <Button Content="Отчет" Style="{StaticResource MainButtonStyle}"
                                Click="btnSessionReport_Click"/>
                    </StackPanel>

                    <DataGrid Grid.Row="2" x:Name="dgSessions"
                              Style="{StaticResource ModernDataGridStyle}"
                              CellStyle="{StaticResource DataGridCellStyle}"
                              ColumnHeaderStyle="{StaticResource DataGridColumnHeaderStyle}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding SessionId}" Width="50"/>
                            <DataGridTextColumn Header="Пользователь" Binding="{Binding User.Name}" Width="120"/>
                            <DataGridTextColumn Header="Игра" Binding="{Binding Game.Title}" Width="120"/>
                            <DataGridTextColumn Header="Начало" Binding="{Binding StartTime, StringFormat=dd.MM.yyyy HH:mm}" Width="150"/>
                            <DataGridTextColumn Header="Конец" Binding="{Binding EndTime, StringFormat=dd.MM.yyyy HH:mm}" Width="150"/>
                            <DataGridTextColumn Header="Стоимость" Binding="{Binding TotalPrice, StringFormat=N2}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>