<Window x:Class="PakDzal_Games_WPF.SessionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Сессия"
        Height="480" Width="450"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource BackgroundDarkBrush}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="Пользователь:*" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,5"/>
            <ComboBox x:Name="cmbUser" Style="{StaticResource ModernComboBoxStyle}"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Margin="0,0,0,10">
            <TextBlock Text="Игра:*" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,5"/>
            <ComboBox x:Name="cmbGame" Style="{StaticResource ModernComboBoxStyle}"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Margin="0,0,0,10">
            <TextBlock Text="Время начала:*" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,5"/>
            <DatePicker x:Name="dtpStart" Background="White" Foreground="Black"/>
        </StackPanel>

        <StackPanel Grid.Row="3" Margin="0,0,0,10">
            <TextBlock Text="Время окончания:*" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,5"/>
            <DatePicker x:Name="dtpEnd" Background="White" Foreground="Black"/>
        </StackPanel>

        <TextBlock Grid.Row="4" Text="* - обязательные поля" 
                   Foreground="{StaticResource TextSecondaryBrush}" 
                   FontSize="11"/>

        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Сохранить" Style="{StaticResource MainButtonStyle}" Click="btnSave_Click"/>
            <Button Content="Отмена" Style="{StaticResource SecondaryButtonStyle}" Click="btnCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>