<Window x:Class="PakDzal_Games_WPF.UserDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Пользователь"
        Height="450" Width="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource BackgroundDarkBrush}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="Имя:*" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,5"/>
            <TextBox x:Name="txtName" Style="{StaticResource ModernTextBoxStyle}"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Margin="0,0,0,10">
            <TextBlock Text="Email:*" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,5"/>
            <TextBox x:Name="txtEmail" Style="{StaticResource ModernTextBoxStyle}"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Margin="0,0,0,10">
            <TextBlock Text="Телефон:" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,5"/>
            <TextBox x:Name="txtPhone" Style="{StaticResource ModernTextBoxStyle}"/>
        </StackPanel>

        <StackPanel Grid.Row="3" Margin="0,0,0,10">
            <TextBlock Text="Город:" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,5"/>
            <TextBox x:Name="txtCity" Style="{StaticResource ModernTextBoxStyle}"/>
        </StackPanel>

        <TextBlock Grid.Row="4" Text="* - обязательные поля" 
                   Foreground="{StaticResource TextSecondaryBrush}" 
                   FontSize="11" Margin="0,10,0,0"/>

        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Сохранить" Style="{StaticResource MainButtonStyle}" Click="btnSave_Click"/>
            <Button Content="Отмена" Style="{StaticResource SecondaryButtonStyle}" Click="btnCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>